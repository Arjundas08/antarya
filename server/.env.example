# ===========================================
# ANTARYA – API Keys Configuration
# ===========================================
# Copy this file to .env and fill in your keys

# Google Gemini API (free tier)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bhashini API (Indian govt speech/translation)
# Get from: https://bhashini.gov.in/ulca/user/login → My Profile
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_API_KEY=your_bhashini_api_key_here

# JWT Secret (auto-generated if not set)
JWT_SECRET=antarya-secret-key-2024

# Server Port
PORT=5001
